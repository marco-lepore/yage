{
  "name": "yage",
  "version": "0.0.1",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "scripts": {
    "dev": "vite dev",
    "build:watch": "concurrently \"npm run build-cjs:watch\"  \"npm run build-esm:watch\" \"npm run build-types:watch\"",
    "build-types:watch": "tsc --project ./tsconfig.types.json --watch",
    "build-cjs:watch": "tsc --project ./tsconfig.cjs.json --watch",
    "build-esm:watch": "tsc --project ./tsconfig.esm.json --watch",
    "start": "vite build && vite",
    "watch": "vite build --watch",
    "build-types": "tsc --project ./tsconfig.types.json",
    "build-cjs": "tsc --project ./tsconfig.cjs.json",
    "build-esm": "tsc --project ./tsconfig.esm.json",
    "build": "npx del-cli dist && npm run build-cjs && npm run build-esm && npm run build-types && echo 'Successfully built'",
    "docs": "typedoc --out ./docs/ --readme README.md ./src/",
    "lint": "eslint . --ignore-path .gitignore",
    "test": "vitest --run --reporter verbose",
    "prepare": "npm run build"
  },
  "files": [
    "dist/",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^18.14.6",
    "@typescript-eslint/eslint-plugin": "^6.5.0",
    "@typescript-eslint/parser": "^6.5.0",
    "concurrently": "^8.2.0",
    "del-cli": "^5.0.0",
    "eslint": "^8.48.0",
    "eslint-plugin-unicorn": "^48.0.1",
    "prettier": "^2.8.8",
    "typescript": "^5.0.2",
    "vite": "^4.3.9",
    "vite-plugin-dts": "^2.3.0",
    "vitest": "^0.29.2"
  },
  "dependencies": {
    "@dimforge/rapier2d": "^0.11.2",
    "@pixi/particle-emitter": "^5.0.8",
    "@pixi/sound": "^5.2.0",
    "@pixi/tilemap": "github:marcoinscatola/pixi-tilemap",
    "@pixi/ui": "^0.7.3",
    "@types/lodash": "^4.14.196",
    "eslint-plugin-yage": "github:marcoinscatola/eslint-plugin-yage",
    "lodash": "^4.17.21",
    "pixi-filters": "^5.2.1",
    "pixi-viewport": "^5.0.1",
    "pixi.js": "^7.0.4",
    "vite-plugin-top-level-await": "^1.3.1",
    "vite-plugin-wasm": "^3.2.2",
    "xstate": "^4.37.2"
  },
  "peerDependencies": {
    "@dimforge/rapier2d": "^0.11.2",
    "@pixi/particle-emitter": "^5.0.8",
    "@pixi/sound": "^5.2.0",
    "@pixi/tilemap": "github:marcoinscatola/pixi-tilemap",
    "@pixi/ui": "^0.7.3",
    "pixi-filters": "^5.2.1",
    "pixi-viewport": "^5.0.1",
    "pixi.js": "^7.0.4",
    "xstate": "^4.37.2"
  }
}
