{
  "name": "@yagejs/ui-react",
  "version": "0.5.0",
  "description": "React bindings for building game UI with JSX in YAGE",
  "keywords": [
    "yage",
    "game-engine",
    "2d",
    "typescript",
    "ui",
    "react",
    "jsx",
    "react-reconciler"
  ],
  "license": "MIT",
  "author": "Marco Lepore",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marco-lepore/yage.git",
    "directory": "packages/ui-react"
  },
  "homepage": "https://yage.dev",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@yagejs/core": "^0.5.0",
    "@yagejs/renderer": "^0.5.0",
    "@yagejs/ui": "^0.5.0",
    "pixi.js": "^8.5.0",
    "react-reconciler": "^0.31.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@types/react-reconciler": "^0.28.9",
    "react": "^19.0.0",
    "react-dom": "^19.2.4"
  }
}
