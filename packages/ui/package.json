{
  "name": "@yagejs/ui",
  "version": "0.1.0",
  "description": "In-game UI layout and widgets for YAGE",
  "keywords": [
    "yage",
    "game-engine",
    "2d",
    "typescript",
    "ui",
    "gui",
    "layout",
    "flexbox",
    "yoga"
  ],
  "license": "MIT",
  "author": "Marco Lepore",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marco-lepore/yage.git",
    "directory": "packages/ui"
  },
  "homepage": "https://yage.dev",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pixi/ui": "^2.3.2",
    "@yagejs/core": "^0.1.0",
    "@yagejs/renderer": "^0.1.0",
    "pixi.js": "^8.5.0",
    "yoga-layout": "^3.2.1"
  }
}
