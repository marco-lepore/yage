{
  "name": "create-yage",
  "version": "0.1.1",
  "description": "Scaffold a new YAGE 2D game engine project",
  "keywords": [
    "yage",
    "game-engine",
    "2d",
    "typescript",
    "create",
    "scaffold",
    "starter",
    "template",
    "vite"
  ],
  "license": "MIT",
  "author": "Marco Lepore",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marco-lepore/yage.git",
    "directory": "packages/create-yage"
  },
  "homepage": "https://yage.dev",
  "type": "module",
  "bin": {
    "create-yage": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "sync-template-versions": "node ../../scripts/sync-template-versions.mjs",
    "prepublishOnly": "npm run sync-template-versions && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0"
  }
}
