{
  "name": "@yagejs/renderer",
  "version": "0.1.0",
  "description": "PixiJS v8 rendering pipeline, sprites, graphics, and cameras for YAGE",
  "keywords": [
    "yage",
    "game-engine",
    "2d",
    "typescript",
    "rendering",
    "pixijs",
    "pixi",
    "sprite",
    "graphics"
  ],
  "license": "MIT",
  "author": "Marco Lepore",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marco-lepore/yage.git",
    "directory": "packages/renderer"
  },
  "homepage": "https://yage.dev",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./api": {
      "import": {
        "types": "./dist/api.d.ts",
        "default": "./dist/api.js"
      },
      "require": {
        "types": "./dist/api.d.cts",
        "default": "./dist/api.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@yagejs/core": "^0.1.0",
    "pixi.js": "^8.5.0"
  }
}
