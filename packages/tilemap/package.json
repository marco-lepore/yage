{
  "name": "@yage/tilemap",
  "version": "0.1.0",
  "license": "MIT",
  "author": "Marco Lepore",
  "repository": {
    "type": "git",
    "url": "https://github.com/marco-lepore/yage.git",
    "directory": "packages/tilemap"
  },
  "homepage": "https://yage.dev",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@yage/core": "*",
    "@yage/renderer": "*",
    "@pixi/tilemap": "^5.0.0",
    "pixi.js": "^8.5.0"
  },
  "devDependencies": {
    "@yage/physics": "*"
  }
}
